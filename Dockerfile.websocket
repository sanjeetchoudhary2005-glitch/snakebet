# syntax=docker/dockerfile:1

FROM node:22-alpine
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY prisma ./prisma
COPY server ./server
COPY lib ./lib
COPY tsconfig.json ./
RUN npx prisma generate
ENV NODE_ENV=production
ENV WS_HOST=0.0.0.0
ENV WS_PORT=8080
EXPOSE 8080
CMD ["npx", "tsx", "server/websocket.ts"]
