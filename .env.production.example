# Database (MySQL)
DATABASE_URL="mysql://user:password@host:port/database_name"

# Auth and session signing (min 32 chars in production)
SESSION_SECRET=
AUTH_SECRET=
JWT_SECRET=

# OAuth — see docs/DEPLOYMENT.md for redirect URIs
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# Email (Resend) — signup OTP + password reset
RESEND_API_KEY=
EMAIL_FROM=

# Admin bootstrap and access controls
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_IPS=

# Payments (use live keys in production)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# App/runtime
NEXT_PUBLIC_APP_URL=
NODE_ENV=production
ENCRYPTION_KEY=

# Optional Upstash rate limiting (recommended)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# WebSocket service (separate process — see docs/DEPLOYMENT.md)
WS_HOST=
WS_PORT=

# Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
HEALTH_ALERT_WEBHOOK_URL=
