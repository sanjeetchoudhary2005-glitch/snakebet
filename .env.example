
# Snakebet — Environment Variables
# Copy to .env.local (dev) or your host's secret manager (production).
# =============================================================================

# --- Database ---
# Local dev (SQLite, default):
# DATABASE_URL="file:./dev.db"
#
# Production / Docker (MySQL):
# 1. In prisma/schema.prisma: change datasource db.provider to "mysql"
# 2. DATABASE_URL="mysql://user:password@host:port/database_name"
#
# Production / Docker (PostgreSQL):
# 1. In prisma/schema.prisma: change datasource db.provider to "postgresql"
# 2. DATABASE_URL="postgresql://Snakebet:Snakebet@localhost:5432/Snakebet"

# --- Session & Auth ---
# Required in production. Minimum 32 random characters.
SESSION_SECRET="your-session-secret-here-min-32-chars"
# NextAuth / Auth.js secret (can match SESSION_SECRET)
AUTH_SECRET="your-auth-secret-here-min-32-chars"
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef"

# --- OAuth (Google / Facebook) ---
# Google Cloud Console → OAuth client → Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google
#   https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Meta Developer → Facebook Login → Valid OAuth Redirect URIs (same pattern):
#   http://localhost:3000/api/auth/callback/facebook
#   https://YOUR_DOMAIN/api/auth/callback/facebook
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# --- Email (Resend) — signup OTP + password reset ---
# https://resend.com — verify your sending domain for production
RESEND_API_KEY=
EMAIL_FROM="Snakebet <noreply@yourdomain.com>"

# --- SMS OTP (optional, not required for email-only signup) ---
MSG91_AUTH_KEY=

# --- Admin ---
ADMIN_EMAIL=admin@Snakebet.local
ADMIN_PASSWORD=change-me-in-production
# Comma-separated IPs allowed to access /admin (empty = no IP restriction)
ADMIN_IPS=

# --- Payments (Razorpay) ---
# Use test keys for staging; live keys for production (never commit real keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_UPI_ID=merchant@upi

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Rate limiting (Upstash Redis — recommended for production) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- WebSocket (separate long-lived process: npm run websocket) ---
# On Vercel/serverless, deploy Dockerfile.websocket to Fly.io/Railway/ECS instead.
WS_HOST=127.0.0.1
WS_PORT=8080
WS_BROADCAST_PORT=8091
WS_INTERNAL_SECRET=dev-internal-change-me-in-production
NEXT_PUBLIC_WS_URL=ws://localhost:8080
# Minimum win amount (INR) shown on homepage live ticker
LIVE_WIN_THRESHOLD=100

# --- Monitoring ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Optional webhook for health-check failures (Slack/Discord incoming webhook URL)
HEALTH_ALERT_WEBHOOK_URL=

# --- House liquidity caps (optional) ---
MAX_EXPOSURE_PCT=0.10
MAX_GAME_EXPOSURE_PCT=0.30
